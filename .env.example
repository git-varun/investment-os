# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=aureon
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aureon
DATABASE_URL=postgresql://aureon:change_me_strong_password@aureon-db:5432/aureon

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=aureon
RABBITMQ_PASS=change_me_rabbitmq_password
CELERY_BROKER_URL=amqp://aureon:change_me_rabbitmq_password@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Ports ─────────────────────────────────────────────────────────────────────
API_PORT=8001
FRONTEND_PORT=3000

# ── API ───────────────────────────────────────────────────────────────────────
ENABLE_API_DOCS=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=["https://yourdomain.com"]

# ── Frontend URL (used for magic link emails) ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email / SMTP (optional — OTPs logged in dev mode if unset) ────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aureon.app

# ── Textbelt / SMS OTP (open-source, self-hostable — OTPs logged in dev mode if unset) ──
# Self-hosted:  TEXTBELT_URL=http://your-host:9090/text  TEXTBELT_API_KEY=textbelt
# Free tier:    leave TEXTBELT_URL blank, set TEXTBELT_API_KEY=textbelt (1 SMS/day)
# Paid key:     set TEXTBELT_API_KEY to your purchased key
TEXTBELT_URL=https://textbelt.com/text
TEXTBELT_API_KEY=

# ── Google OAuth (optional — /auth/google returns ConfigError if unset) ────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── External APIs (optional) ──────────────────────────────────────────────────
GEMINI_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
GROWW_AUTH_TOKEN=
