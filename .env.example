# Investment OS Environment Configuration (Production-Ready Modular Monolith)
# Copy this to .env and fill in your actual values

# ===== DATABASE (PostgreSQL) =====
DATABASE_URL=postgresql://admin:admin@localhost:5432/investment_os

# ===== CACHE (Redis - OPTIONAL) =====
# Leave empty to disable cache.
REDIS_URL=

# ===== MESSAGE QUEUE (Celery - OPTIONAL) =====
# Leave empty to run celery tasks eagerly in-process.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ===== BROKER API CREDENTIALS =====
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_ACCESS_TOKEN=your_daily_zerodha_access_token
# Generate daily via: kite.generate_session(request_token, api_secret) -> access_token

GROWW_API_KEY=your_groww_api_key
GROWW_API_SECRET=your_groww_api_secret

# ===== MARKET DATA =====
FINNHUB_API_KEY=your_finnhub_api_key

# ===== AI & NOTIFICATIONS =====
GEMINI_API_KEY=your_gemini_api_key

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===== SECURITY =====
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-hex-secret

# ===== APP CONFIG =====
API_TITLE=Investment OS API
API_VERSION=7.0
DEBUG=false
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata
